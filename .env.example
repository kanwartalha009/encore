# Encore — env template. Copy to .env (gitignored) and fill the blanks.
# Secrets are write-only: never commit; in prod use the host's secret manager.

# ── Shopify app (per app) ───────────────────────────────
SHOPIFY_API_KEY=98895e8868ecb5c8555ab43039b554e1
SHOPIFY_API_SECRET=                 # secret · ALSO the webhook HMAC key · Dev Dashboard → Encore → API credentials
SHOPIFY_APP_URL=https://encore.nova-platform.localhost:3003
# NOTE: shopify.app.toml [access_scopes] is the source of truth; keep this in sync.
SCOPES=read_products,write_products,write_purchase_options,read_inventory,read_locations,read_orders,write_orders,read_markets,read_customers,read_themes,read_discounts,write_metaobjects,write_metaobject_definitions

# ── Shopify org / CI ────────────────────────────────────
SHOPIFY_ORG_ID=1710157
SHOPIFY_CLI_PARTNERS_TOKEN=         # secret · CI only (headless app deploy)

# ── Per-app database (isolated Postgres — never the platform DB) ──
APP_DB_URL__ENCORE=                 # secret · e.g. postgresql://postgres:postgres@localhost:5432/app_encore

# ── Crypto ──────────────────────────────────────────────
APP_ENCRYPTION_KEY=                 # secret · 32 bytes as 64 hex chars · encrypts Shop.accessTokenEnc

# ── Nova platform wiring (see NOVA-INTEGRATION-CONTRACT.md) ──
NOVA_API=https://api.nova-apps.example
NOVA_INGRESS_HMAC_SECRET=           # secret · signs forwarded webhooks (X-Nova-Signature)
NOVA_INSTALL_CONFIRM_SECRET=        # secret · signs the install-confirm callback (X-Nova-Signature)

# ── ARRS recovery engine (Phase 3) ──────────────────────
ARRS_API_BASE=
ARRS_API_KEY=                       # secret

# ── Scheduled jobs (Phase 4) ────────────────────────────
ENCORE_CRON_SECRET=                 # secret · bearer token guarding POST /cron/purge-uninstalled (GDPR 48h purge)

# ── Klaviyo OAuth (N4 · productized Klaviyo connection) ──
# Register an Encore app in Klaviyo (developers.klaviyo.com) with redirect
# {SHOPIFY_APP_URL}/klaviyo/callback. Without these, merchants paste a private key.
ENCORE_KLAVIYO_CLIENT_ID=
ENCORE_KLAVIYO_CLIENT_SECRET=       # secret

# ── Transactional email (N1 · Shopify-Flow notification path) ──
# Only needed when a merchant picks the "Shopify Flow" provider — Encore sends the
# customer email the Flow action requests. Provider-agnostic (Resend-style default).
ENCORE_EMAIL_API_URL=               # default https://api.resend.com/emails (swap for SendGrid/Postmark/SES)
ENCORE_EMAIL_API_KEY=               # secret · transactional provider key
ENCORE_EMAIL_FROM=                  # verified sender, e.g. "Acme <preorders@acme.com>"
